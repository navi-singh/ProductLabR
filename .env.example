# Production canonical URL — used for metadataBase, sitemap, robots.txt, JSON-LD
# Must include protocol; no trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google AdSense publisher ID (e.g. ca-pub-1234567890123456)
# Required in production builds; build will fail if unset.
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# Optional — if unset, GA is not loaded (useful for dev/preview).
NEXT_PUBLIC_GA_ID=
